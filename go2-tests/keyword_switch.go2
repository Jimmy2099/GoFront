package main
import "fmt"

func classify(value int) int {
    result := 0
    switch value {
    case 1:
        result = 10
        fallthrough
    case 2:
        result = result + 2
    default:
        result = 99
    }
    return result
}

func main() {
    fmt.Println(classify(1), classify(2), classify(3))
}
