package main
import "fmt"
#include <map>
#include <string>
#include <vector>

type Counter struct {
    total int
}

type Marker interface {
    describe(prefix string) string
}

func countWords() int {
    const expected int = 3
    var words []string = []string{"if", "for", "map"}
    counts := map[string]int{}
    counter := Counter{}

    for _, word := range words {
        counts[word] = 1
        counter.total = counter.total + 1
    }

    if counter.total == expected {
        return counts["map"] + counter.total
    } else {
        return 0
    }
}

func main() {
    fmt.Println(countWords())
}
