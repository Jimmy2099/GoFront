package main
import "fmt"
#include <array>
#include <map>
#include <vector>

type Profile struct {
    name string
    score int
}

func renamed(profile Profile) Profile {
    profile.name = profile.name + "!"
    return profile
}

func addScore(profile *Profile, delta int) {
    profile.score = profile.score + delta
}

func main() {
    profile := Profile{}
    profile.name = "Ada"
    profile.score = 10
    addScore(&profile, 5)
    updated := renamed(profile)

    numbers := []int{3, 4, 5}
    numbers[1] = numbers[0] + numbers[2]
    fixed := [3]int{7, 8, 9}
    scores := map[string]int{}
    scores["Ada"] = updated.score + numbers[1] + fixed[2]

    fmt.Println(updated.name, profile.score, numbers[1], fixed[0], scores["Ada"])
}
